        "rollover_recurring_to_planned_after_done": true,
        "one_shot_no_auto_reappear": true,
        "no_cross_scope_links_without_explicit_request": true,
        "linkref_contract": {
            "required": [
                "type",
                "ref_id"
            ],
            "optional": [
                "path"
            ]
        }
    }

{
    "meta": {
        "document_type": "skill_rules",
        "module": "patch",
        "version": "3.1.0",
        "updated_at": "2026-04-12T00:00:00+02:00"
    },
    "patch_contract": {
        "reference_docs": [
            "references/usage-patch.md"
        ],
        "explicit_user_write_instruction_required": true,
        "silent_write_forbidden": true,
        "default_write_scope": [
            "data.canonique",
            "todo"
        ],
        "other_sections_only_on_explicit_request": true,
        "schema_drift_forbidden": true,
        "minimal_change_only": true,
        "missing_or_ambiguous_info_policy": "ask_or_park_in_notes",
        "preserve_unspecified_existing_values": true,
        "todo_links_required": true
    },
    "output_modes": {
        "allowed": [
            "FULL_REPLACE",
            "MERGE_PATCH_RFC7396",
            "PATCH_RFC6902"
        ],
        "recommended_default": "MERGE_PATCH_RFC7396",
        "full_replace_fallback_allowed": true,
        "patch_rfc6902_only_if_consumer_supports_it": true,
        "merge_patch_unspecified_fields_preserved": true,
        "payload_must_be_json_only": true,
        "envelope_fields": [
            "mode",
            "target_filename",
            "scope",
            "payload"
        ]
    }
}

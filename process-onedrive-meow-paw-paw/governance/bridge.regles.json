    "meow_journal_file": "C:/Users/engue/OneDrive/__SYSTEME - PERSONA_O.S__/GPT/MEOW PAW PAW/MEOW PAW PAW ATTACHEMENTS/[ MEOW ] Journal.md",
    "meow_journal_chain_pattern": "C:/Users/engue/OneDrive/__SYSTEME - PERSONA_O.S__/GPT/MEOW PAW PAW/MEOW PAW PAW ATTACHEMENTS/[ MEOW ] Journal_{n}.md",
    "todo_journal_file": "C:/Users/engue/OneDrive/__SYSTEME - PERSONA_O.S__/GPT/TODO/TODO ATTACHEMENTS/[ TODO ] Journal.md",
    "path_handling_policy": "use_literal_path_for_bracket_filenames",
    "append_only": true,
    "required_block_template": [
